# Database (Supabase Local)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# 本番のみ推奨: drizzle-kit migrate / pnpm build 用の直結 URL（Supabase Dashboard の Connection string → Direct / ポート 5432）
# 未設定時は DATABASE_URL をマイグレーションにも使う（ローカルはこのままでよい）
# DATABASE_URL_MIGRATE=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Better Auth
# 下記コマンドで生成したものを設定してください
# openssl rand -base64 32
BETTER_AUTH_SECRET=openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth
# 作成手順:
#   1. https://github.com/settings/developers にアクセス
#   2. "New OAuth App" をクリック
#   3. 以下を入力:
#      - Application name: 任意（例: BIS-Template Local）
#      - Homepage URL: http://localhost:3000
#      - Authorization callback URL: http://localhost:3000/api/auth/callback/github
#   4. "Register application" をクリック
#   5. Client ID をコピーして GITHUB_CLIENT_ID に設定
#   6. "Generate a new client secret" をクリックし、GITHUB_CLIENT_SECRET に設定
GITHUB_CLIENT_ID=your-client-id
GITHUB_CLIENT_SECRET=your-client-secret

# Supabase Storage（プロフィール画像・サーバー専用キーはクライアントに含めない）
# PROFILE_AVATAR_BUCKET と同名のバケットを Supabase Dashboard → Storage で作成すること（未作成だとアップロードが失敗する）
# 公開画像 URL は主に SUPABASE_URL 基準。next/image 用に NEXT_PUBLIC_* も設定し、localhost と 127.0.0.1 が混ざる場合は next.config が両方を許可する
PROFILE_AVATAR_BUCKET=profile-avatar
SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU"
